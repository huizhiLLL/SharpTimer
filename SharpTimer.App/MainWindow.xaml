<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SharpTimer.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SharpTimer">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="RootGrid"
        IsTabStop="True"
        KeyDown="RootGrid_KeyDown"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="28,20"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="8">
                    <TextBlock
                        Text="SharpTimer"
                        FontSize="22"
                        FontWeight="SemiBold" />
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8">
                        <ComboBox
                            x:Name="SessionComboBox"
                            MinWidth="220"
                            DisplayMemberPath="DisplayName"
                            SelectionChanged="SessionComboBox_SelectionChanged" />
                        <Button
                            Content="新建"
                            Click="NewSessionButton_Click" />
                        <Button
                            Content="重命名"
                            Click="RenameSessionButton_Click" />
                        <Button
                            Content="归档"
                            Click="ArchiveSessionButton_Click" />
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        x:Name="PrimaryActionButton"
                        MinWidth="96"
                        Click="PrimaryActionButton_Click" />
                    <Button
                        Content="重置"
                        Click="ResetButton_Click" />
                    <Button
                        Content="设置"
                        Click="SettingsButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid
            Grid.Row="1"
            Padding="28"
            ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Grid RowSpacing="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
                    <TextBlock
                        x:Name="PhaseText"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        FontSize="18" />
                    <TextBlock
                        x:Name="TimerText"
                        HorizontalAlignment="Center"
                        FontFamily="Consolas"
                        FontSize="96"
                        FontWeight="SemiBold" />
                    <TextBlock
                        x:Name="InspectionText"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        FontSize="18" />
                </StackPanel>

                <Grid
                    Grid.Row="1"
                    ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Padding="16"
                        CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Best" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="BestText" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border
                        Grid.Column="1"
                        Padding="16"
                        CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Mean" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="MeanText" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border
                        Grid.Column="2"
                        Padding="16"
                        CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Ao5" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="Ao5Text" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border
                        Grid.Column="3"
                        Padding="16"
                        CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Ao12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="Ao12Text" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid
                Grid.Column="1"
                RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Text="成绩"
                        FontSize="20"
                        FontWeight="SemiBold" />
                    <TextBlock
                        x:Name="CountText"
                        Grid.Column="1"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        VerticalAlignment="Center" />
                </Grid>

                <ListView
                    x:Name="SolvesList"
                    Grid.Row="1"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid
                                Padding="4,8"
                                ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="56" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Text="{Binding Number}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock
                                        Text="{Binding Time}"
                                        FontSize="18"
                                        FontWeight="SemiBold" />
                                    <TextBlock
                                        Text="{Binding CreatedAt}"
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Column="2"
                                    Text="{Binding Penalty}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel
                    Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="8"
                    HorizontalAlignment="Right">
                    <Button
                        Content="+2"
                        Click="PlusTwoButton_Click" />
                    <Button
                        Content="DNF"
                        Click="DnfButton_Click" />
                    <Button
                        Content="清除罚时"
                        Click="ClearPenaltyButton_Click" />
                    <Button
                        Content="删除"
                        Click="DeleteButton_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
